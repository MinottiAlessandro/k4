#!/usr/bin/env bash
# k4 — push files to a Kindle running KOReader over SSH.

set -euo pipefail

readonly CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/k4.config"

book_dir="/mnt/us/documents"
authorized_keys_file="/mnt/us/koreader/settings/SSH/authorized_keys"
wallpaper_dir="/mnt/us/wallpaper"
patches_dir="/mnt/us/koreader/patches"

ip=""
port="22"
user="root"
assume_yes=0
recursive=0

usage() {
  cat <<EOF
k4 — push files to a Kindle running KOReader over SSH

Usage:
  k4 [SUBCOMMAND] [OPTIONS] [PATH]

Subcommands:
  book, b              Upload a book to $book_dir/ (default)
  authorized-key, a    Append a public key to $authorized_keys_file
  wallpaper, w         Upload an image to $wallpaper_dir/
  add-patch, p         Upload a lua patch to $patches_dir/
                       (filename must be '<digits>-<name>.lua')
  check, c             Test the SSH connection and report remote dir status

Options:
  --ip      <addr>   Device IP address (required if not in config)
  --port    <port>   SSH port (default: $port)
  --user    <user>   SSH user (default: $user)
  --recursive, -r    Treat PATH as a directory and upload its top-level files
                     (book, wallpaper, add-patch; non-matching files skipped)
  --yes, -y          Auto-create missing remote directories without prompting
  --help             Show this help

Config:
  Defaults are read from $CONFIG_FILE if present.
  The file is sourced as shell; use lowercase keys:
      ip="192.168.1.100"
      port="22"
      user="root"
      book_dir="$book_dir"
      authorized_keys_file="$authorized_keys_file"
      wallpaper_dir="$wallpaper_dir"
      patches_dir="$patches_dir"
  Command-line options override config values.
EOF
}

if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
fi

subcommand=""
file=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --ip)    ip="$2";   shift 2 ;;
    --port)  port="$2"; shift 2 ;;
    --user)  user="$2"; shift 2 ;;
    --recursive|-r) recursive=1; shift ;;
    --yes|-y)  assume_yes=1; shift ;;
    --help|-h) usage; exit 0 ;;
    book|b)            subcommand="book";           shift ;;
    authorized-key|a)  subcommand="authorized-key"; shift ;;
    wallpaper|w)       subcommand="wallpaper";      shift ;;
    add-patch|p)       subcommand="add-patch";      shift ;;
    check|c)           subcommand="check";          shift ;;
    --) shift; break ;;
    -*) echo "unknown option: $1" >&2; usage >&2; exit 2 ;;
    *)
      if [[ -z "$file" ]]; then file="$1"
      else echo "unexpected argument: $1" >&2; exit 2
      fi
      shift ;;
  esac
done

subcommand="${subcommand:-book}"

bold=$(tput bold 2>/dev/null || true)
reset=$(tput sgr0 2>/dev/null || true)
green=$(tput setaf 2 2>/dev/null || true)
red=$(tput setaf 1 2>/dev/null || true)
dim=$(tput dim 2>/dev/null || true)

err()  { echo "${red}error:${reset} $*" >&2; exit 1; }
ok()   { echo "${green}✓${reset} $*"; }
fail() { echo "${red}✗${reset} $*" >&2; exit 1; }

[[ -n "$ip" ]] || err "--ip is required (or set 'ip' in $CONFIG_FILE)"

if [[ "$subcommand" == "check" ]]; then
  (( recursive )) && err "--recursive is not valid with 'check'"
elif (( recursive )); then
  case "$subcommand" in
    book|wallpaper|add-patch) ;;
    *) err "--recursive is only valid with book, wallpaper, or add-patch" ;;
  esac
  [[ -n "$file" ]] || err "missing DIR argument (run with --help for usage)"
  [[ -d "$file" ]] || err "not a directory: $file"
else
  [[ -n "$file" ]] || err "missing FILE argument (run with --help for usage)"
  [[ -f "$file" ]] || err "file not found: $file"
fi

summary() {
  echo "${bold}k4${reset} ${dim}─${reset} $subcommand"
  if (( recursive )); then
    echo "  source: $file/ ${dim}(recursive, top-level files)${reset}"
  else
    echo "  file:   $file"
  fi
  echo "  target: $user@$ip:$port"
  echo "  dest:   $1"
  echo
}

ensure_remote_dir() {
  local remote_dir="$1"
  local rc=0
  ssh -p "$port" "$user@$ip" "test -d $remote_dir" || rc=$?
  case "$rc" in
    0)   return 0 ;;
    1)   ;;  # remote reported missing — fall through to prompt
    255) fail "ssh connection failed — is $user@$ip:$port reachable?" ;;
    *)   fail "unexpected ssh exit code $rc while checking $remote_dir" ;;
  esac
  echo "${red}!${reset} remote directory does not exist: $remote_dir"
  local answer=""
  if (( assume_yes )); then
    answer="y"
  elif [[ -t 0 ]]; then
    read -r -p "create it? [y/N] " answer || answer=""
  else
    fail "remote directory missing and no TTY available; rerun with --yes to auto-create"
  fi
  case "$answer" in
    y|Y|yes|YES) ;;
    *) fail "aborted: remote directory not created" ;;
  esac
  if ssh -p "$port" "$user@$ip" "mkdir -p $remote_dir"; then
    ok "created $remote_dir"
  else
    fail "failed to create $remote_dir"
  fi
}

# Validators take a path and print nothing on success; on failure they print a
# one-line reason and return 1. Callers decide whether to fail or skip.
validate_public_key() {
  ssh-keygen -l -f "$1" >/dev/null 2>&1 && return 0
  echo "not a valid SSH public key"; return 1
}

validate_image() {
  local mime
  mime=$(file --mime-type -b "$1" 2>/dev/null || true)
  [[ "$mime" == image/* ]] && return 0
  echo "not an image (mime: ${mime:-unknown})"; return 1
}

validate_lua_patch() {
  local base lua_err
  base=$(basename "$1")
  if [[ ! "$base" =~ ^[0-9]+-[A-Za-z0-9_-]+\.lua$ ]]; then
    echo "filename must match '<digits>-<name>.lua' (e.g. 123-my_patch.lua)"; return 1
  fi
  command -v luac >/dev/null 2>&1 || { echo "luac not found — install 'lua' to validate patches"; return 1; }
  if ! lua_err=$(luac -p "$1" 2>&1); then
    echo "not a valid lua file: $lua_err"; return 1
  fi
}

# Upload one or more files to a remote directory via scp, validating each with
# the given validator function ("" = no validation). Honors $recursive.
upload_to() {
  local dest_dir="$1" validator="${2:-}"
  summary "$dest_dir/"

  # Validate locally first — don't touch the network for a bad file/empty dir.
  local files=() f reason
  if (( recursive )); then
    shopt -s nullglob
    for f in "$file"/*; do
      [[ -f "$f" ]] || continue   # top-level files only; skip subdirs
      if [[ -n "$validator" ]] && ! reason=$("$validator" "$f"); then
        echo "  ${dim}skip${reset} $(basename "$f") — $reason"
        continue
      fi
      files+=("$f")
    done
    shopt -u nullglob
    (( ${#files[@]} )) || fail "no matching files to upload in $file/"
  else
    if [[ -n "$validator" ]] && ! reason=$("$validator" "$file"); then
      fail "$reason: $file"
    fi
    files=("$file")
  fi

  ensure_remote_dir "$dest_dir"

  if scp -P "$port" "${files[@]}" "$user@$ip:$dest_dir/"; then
    ok "uploaded ${#files[@]} file(s) to $dest_dir/"
  else
    fail "scp failed"
  fi
}

upload_authorized_key() {
  local reason
  if ! reason=$(validate_public_key "$file"); then
    fail "$reason: $file"
  fi
  summary "$authorized_keys_file (append)"
  ensure_remote_dir "$(dirname "$authorized_keys_file")"
  if ssh -p "$port" "$user@$ip" "cat >> $authorized_keys_file" < "$file"; then
    ok "appended to $authorized_keys_file"
  else
    fail "ssh failed"
  fi
}

do_check() {
  echo "${bold}k4${reset} ${dim}─${reset} check"
  echo "  target: $user@$ip:$port"
  echo
  local dirs out rc=0
  dirs="$book_dir $(dirname "$authorized_keys_file") $wallpaper_dir $patches_dir"
  out=$(ssh -o BatchMode=yes -o ConnectTimeout=5 -p "$port" "$user@$ip" \
    "for d in $dirs; do if [ -d \"\$d\" ]; then echo \"ok \$d\"; else echo \"missing \$d\"; fi; done" 2>&1) || rc=$?
  if (( rc != 0 )); then
    [[ -n "$out" ]] && echo "$out" >&2
    fail "cannot connect to $user@$ip:$port — check IP, port, network, and that your SSH key is authorized"
  fi
  ok "connected to $user@$ip:$port"
  echo
  echo "  remote directories:"
  local line status path
  while IFS= read -r line; do
    status=${line%% *}
    path=${line#* }
    if [[ "$status" == "ok" ]]; then
      echo "    ${green}✓${reset} $path"
    else
      echo "    ${red}✗${reset} $path ${dim}(missing)${reset}"
    fi
  done <<< "$out"
}

case "$subcommand" in
  book)           upload_to "$book_dir" ;;
  wallpaper)      upload_to "$wallpaper_dir" validate_image ;;
  add-patch)      upload_to "$patches_dir" validate_lua_patch ;;
  authorized-key) upload_authorized_key ;;
  check)          do_check ;;
esac
